{
  "name": "easyworship-app",
  "version": "1.1.6",
  "description": "Presentation For Church - Worship Presentation App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:all",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.church.presentation",
    "productName": "Presentation For Church",
    "artifactName": "Presentation.For.Church.Setup.${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "live.html",
      "edit-song.html",
      "src/**/*",
      "data/**/*.xml",
      "data/songs.json",
      "fonts/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Presentation For Church"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "mammoth": "^1.12.0"
  }
}
